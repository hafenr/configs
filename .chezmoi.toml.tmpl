# chezmoi config (generated by `chezmoi init`).
# Render mode is the default — managed files are written as real files in $HOME.
{{ if stat (joinPath .chezmoi.homeDir "configs") -}}
sourceDir = {{ (joinPath .chezmoi.homeDir "configs") | quote }}
{{ end -}}

# age encryption.
#   - Encrypting (chezmoi add --encrypt) needs only the recipient (public key,
#     below). Safe to commit; encrypting never touches 1Password.
#   - Decrypting (chezmoi apply/diff/...) goes through our age wrapper
#     (chezmoi-hooks/age-1password.sh), which fetches the private identity from
#     1Password into a tmpfile, runs age, and shreds the tmpfile on exit — all
#     within one process, so the key is never persisted. Requires the 1Password
#     CLI (`op`) to be signed in.
encryption = "age"
[age]
    command = "{{ .chezmoi.sourceDir }}/chezmoi-hooks/age-1password.sh"
    recipient = "age1tfnreee89apdqf3w5rxrxganpxa7clndyytay57uflpxes5ypevq5mdrdq"
