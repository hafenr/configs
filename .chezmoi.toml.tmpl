# chezmoi config (generated by `chezmoi init`).
# Render mode is the default — managed files are written as real files in $HOME.
{{ if stat (joinPath .chezmoi.homeDir "configs") -}}
sourceDir = {{ (joinPath .chezmoi.homeDir "configs") | quote }}
{{ end -}}

# age encryption.
#   - Encrypting (chezmoi add --encrypt) needs only the recipient (public key).
#     It is safe to commit, which is why it lives here.
#   - Decrypting (chezmoi apply) needs the private identity at the path below.
#     The key is NOT committed; copy it once from 1Password to that path:
#       op read 'op://Personal/dotfiles age key/notesPlain' \
#         | sed -n '/AGE-SECRET-KEY/p' > ~/.config/chezmoi/key.txt
#       chmod 600 ~/.config/chezmoi/key.txt
encryption = "age"
[age]
    identity = "{{ .chezmoi.homeDir }}/.config/chezmoi/key.txt"
    recipient = "age1tfnreee89apdqf3w5rxrxganpxa7clndyytay57uflpxes5ypevq5mdrdq"
